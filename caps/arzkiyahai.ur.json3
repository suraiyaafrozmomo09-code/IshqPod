    "tStartMs": 108389,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 108399,
    "dDurationMs": 9601,
    "wWinId": 1,
    "segs": [ {
      "utf8": "ڈوبے دلوں کا کیا؟",
