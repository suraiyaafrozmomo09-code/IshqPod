      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 111600,
    "dDurationMs": 10879,
    "wWinId": 1,
    "segs": [ {
      "utf8": "میں خود بننا چاہتا ہوں، تیری آنکھوں میں تیر نہیں سکتا",
