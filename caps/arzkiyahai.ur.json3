    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 118000,
    "dDurationMs": 9759,
    "wWinId": 1,
    "segs": [ {
      "utf8": "اپنے آپ کو شاعر کی فطرت میں غرق کر دو",
