    "dDurationMs": 6930,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 100960,
    "dDurationMs": 6920,
    "wWinId": 1,
    "segs": [ {
      "utf8": "تم جو چاہو تمہارے حق میں ہو۔",
