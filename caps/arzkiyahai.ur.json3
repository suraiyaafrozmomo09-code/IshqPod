    } ]
  }, {
    "tStartMs": 40480,
    "dDurationMs": 13280,
    "wWinId": 1,
    "segs": [ {
      "utf8": "جو بزدل تھے وہ شاعر بن گئے اب کیا کریں؟",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 47430,
    "dDurationMs": 6330,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 47440,
    "dDurationMs": 12400,
    "wWinId": 1,
    "segs": [ {
      "utf8": "میں نے محبت میں کوئی ایسی بات نہیں کہی جس کی وجہ سے میں اسے ڈھونڈنے کو دل کروں۔",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 53750,
    "dDurationMs": 6090,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 53760,
    "dDurationMs": 10880,
    "wWinId": 1,
    "segs": [ {
      "utf8": "میں نئے محبت کرنے والوں کو چلانے کے لیے کون سے الفاظ استعمال کرتا ہوں۔",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 59830,
    "dDurationMs": 4810,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 59840,
    "dDurationMs": 10160,
    "wWinId": 1,
    "segs": [ {
      "utf8": "عشق میں تیرے ہیں فیض بنے",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 64630,
    "dDurationMs": 5370,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 64640,
    "dDurationMs": 12000,
    "wWinId": 1,
    "segs": [ {
      "utf8": "میں نے درخواست کی ہے کہ میں بھی آپ کے بارے میں کچھ لکھوں۔",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 69990,
    "dDurationMs": 6650,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 70000,
    "dDurationMs": 12400,
    "wWinId": 1,
    "segs": [ {
      "utf8": "میں تم جیسا ہوں، تم گلاب جیسی ہو اور تم ایسے ہو۔",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 76630,
    "dDurationMs": 5770,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 76640,
    "dDurationMs": 12880,
    "wWinId": 1,
    "segs": [ {
      "utf8": "یوں لگتا ہے جیسے دل کے باغوں میں گلاب کے پھول کھل رہے ہیں۔",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 82390,
    "dDurationMs": 7130,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 82400,
    "dDurationMs": 13280,
    "wWinId": 1,
    "segs": [ {
      "utf8": "ان فضاؤں میں سائے پڑ گئے ہیں۔",
      "acAsrConf": 0
    } ]
  }, {
    "tStartMs": 89510,
    "dDurationMs": 6170,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 89520,
    "dDurationMs": 11440,
    "wWinId": 1,
    "segs": [ {
      "utf8": "اور ویسے بھی ہم آپ کے غلام ہیں اور ویسے بھی",
