    } ]
  }, {
    "tStartMs": 95670,
    "dDurationMs": 5290,
    "wWinId": 1,
    "aAppend": 1,
    "segs": [ {
      "utf8": "\n"
    } ]
  }, {
    "tStartMs": 95680,
    "dDurationMs": 12200,
    "wWinId": 1,
    "segs": [ {
      "utf8": "ہم تیرے غلام ہیں دلوں کے بادشاہ",
